# Server-only secrets. Keep real values in .env.local or your hosting provider.
# Do not prefix secrets with NEXT_PUBLIC_.

DIFY_API_URL=https://your-dify-host.example.com/v1/workflows/run
DIFY_API_KEY=replace-with-your-dify-api-key
DIFY_USER_ID=unifeye-web-client

# Optional fallback values for workflow variables.
DIFY_INPUT_ZULIP_EMAIL=you@example.com
DIFY_INPUT_ZULIP_API_KEY=replace-with-your-zulip-api-key

# Optional direct Zulip execution settings.
ZULIP_REALM_URL=https://your-org.zulipchat.com
ZULIP_SUBSCRIPTIONS_URL=
ZULIP_EMAIL=you@example.com
ZULIP_API_KEY=replace-with-your-zulip-api-key
